{%- comment -%}
  XI Feature Highlights — same layout system as XI Trust Bar.
  3 equal columns: icon, uppercase title, uppercase supporting copy.
{%- endcomment -%}

{%- liquid
  assign align = section.settings.alignment
  assign animate = section.settings.enable_animation
-%}

<div
  class="xi-trust{% if animate %} xi-trust--animate{% endif %}"
  style="
    --xi-trust-bg: {{ section.settings.background_color }};
    --xi-trust-text: {{ section.settings.text_color }};
    --xi-trust-muted: {{ section.settings.muted_text_color }};
    --xi-trust-pad-top: {{ section.settings.padding_top }}px;
    --xi-trust-pad-bottom: {{ section.settings.padding_bottom }}px;
  "
  {{ section.shopify_attributes }}
>
  <div class="xi-trust__container xi-container xi-container--wide">
    {%- if section.blocks.size > 0 -%}
      <ul class="xi-trust__grid" data-align="{{ align }}" role="list">
        {%- for block in section.blocks -%}
          {%- liquid
            assign has_link = false
            if block.settings.link != blank
              assign has_link = true
            endif
          -%}
          <li class="xi-trust__item" {{ block.shopify_attributes }}>
            {%- if has_link -%}
              <a class="xi-trust__item-inner xi-trust__item-link" href="{{ block.settings.link }}">
            {%- else -%}
              <div class="xi-trust__item-inner">
            {%- endif -%}

              <span class="xi-trust__icon">
                {%- render 'xi-icons', icon: block.settings.icon, size: 'md', stroke_width: 1.25 -%}
              </span>

              {%- if block.settings.title != blank -%}
                <h3 class="xi-trust__title">{{ block.settings.title | escape }}</h3>
              {%- endif -%}

              {%- if block.settings.copy != blank -%}
                <p class="xi-trust__copy">{{ block.settings.copy | escape }}</p>
              {%- endif -%}

            {%- if has_link -%}
              </a>
            {%- else -%}
              </div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "XI Feature Highlights",
  "tag": "section",
  "class": "xi-home__section-slot xi-home__section-slot--feature-highlights",
  "enabled_on": {
    "templates": ["index"]
  },
  "max_blocks": 3,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 24,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 24,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 50
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f2f2f2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Supporting copy color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Motion"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Subtle fade-up on scroll",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "pocket", "label": "Pocket" },
            { "value": "embroidery", "label": "Embroidery" },
            { "value": "fabric", "label": "Fabric / Fleece" },
            { "value": "hem", "label": "Raised cut / Fit" },
            { "value": "hood", "label": "Hood" },
            { "value": "limited", "label": "Limited release" },
            { "value": "tag", "label": "Tag" },
            { "value": "ruler", "label": "Craft / Fit" },
            { "value": "lock", "label": "Secure" },
            { "value": "star-outline", "label": "Star" },
            { "value": "truck", "label": "Shipping" }
          ],
          "default": "pocket"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Hidden side pocket"
        },
        {
          "type": "text",
          "id": "copy",
          "label": "Supporting copy",
          "default": "For the essentials."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "XI Feature Highlights",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "icon": "pocket",
            "title": "Hidden side pocket",
            "copy": "For the essentials."
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "fabric",
            "title": "Premium fabric",
            "copy": "Heavyweight fleece built to last."
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "tag",
            "title": "Limited drops",
            "copy": "Produced in small batches."
          }
        }
      ]
    }
  ]
}
{% endschema %}
