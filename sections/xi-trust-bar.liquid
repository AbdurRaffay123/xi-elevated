{%- comment -%}
  XI Trust Bar — minimal editorial reassurance row.
  3 equal columns: small icon, uppercase title, short supporting copy.
  No cards, no borders, no shadows. Luxury / minimal.
{%- endcomment -%}

{%- liquid
  assign align = section.settings.alignment
  assign animate = section.settings.enable_animation
-%}

<div
  class="xi-trust{% if animate %} xi-trust--animate{% endif %}"
  style="
    --xi-trust-bg: {{ section.settings.background_color }};
    --xi-trust-text: {{ section.settings.text_color }};
    --xi-trust-muted: {{ section.settings.muted_text_color }};
    --xi-trust-pad-top: {{ section.settings.padding_top }}px;
    --xi-trust-pad-bottom: {{ section.settings.padding_bottom }}px;
  "
  {{ section.shopify_attributes }}
>
  <div class="xi-trust__container xi-container xi-container--wide">
    {%- if section.settings.heading != blank -%}
      <h2 class="xi-trust__heading xi-type-eyebrow" data-align="{{ align }}">
        {{ section.settings.heading | escape }}
      </h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="xi-trust__grid" data-align="{{ align }}" role="list">
        {%- for block in section.blocks -%}
          {%- liquid
            assign has_link = false
            if block.settings.link != blank
              assign has_link = true
            endif
          -%}
          <li class="xi-trust__item" {{ block.shopify_attributes }}>
            {%- if has_link -%}
              <a class="xi-trust__item-inner xi-trust__item-link" href="{{ block.settings.link }}">
            {%- else -%}
              <div class="xi-trust__item-inner">
            {%- endif -%}

              <span class="xi-trust__icon">
                {%- render 'xi-icons', icon: block.settings.icon, size: 'md', stroke_width: 1.25 -%}
              </span>

              {%- if block.settings.title != blank -%}
                <h3 class="xi-trust__title">{{ block.settings.title | escape }}</h3>
              {%- endif -%}

              {%- if block.settings.copy != blank -%}
                <p class="xi-trust__copy">{{ block.settings.copy | escape }}</p>
              {%- endif -%}

            {%- if has_link -%}
              </a>
            {%- else -%}
              </div>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "XI Trust Bar",
  "tag": "section",
  "class": "xi-home__section-slot xi-home__section-slot--trust-bar",
  "enabled_on": {
    "templates": ["index"]
  },
  "max_blocks": 4,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "info": "Optional. Small eyebrow label above the row."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 24,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 24,
      "max": 160,
      "step": 2,
      "unit": "px",
      "default": 50
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f2f2f2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Supporting copy color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Motion"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Subtle fade-up on scroll",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Trust item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "truck", "label": "Shipping" },
            { "value": "star-outline", "label": "Star (outline)" },
            { "value": "star", "label": "Star (filled)" },
            { "value": "lock", "label": "Secure / Limited" },
            { "value": "ruler", "label": "Fit / Craft" },
            { "value": "cart", "label": "Cart" },
            { "value": "account", "label": "Account" },
            { "value": "search", "label": "Search" },
            { "value": "arrow", "label": "Arrow" }
          ],
          "default": "truck"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free shipping"
        },
        {
          "type": "text",
          "id": "copy",
          "label": "Supporting copy",
          "default": "On orders over $100"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "XI Trust Bar",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "icon": "truck",
            "title": "Free shipping",
            "copy": "On orders over $150"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "lock",
            "title": "Secure checkout",
            "copy": "Safe & encrypted"
          }
        },
        {
          "type": "item",
          "settings": {
            "icon": "star-outline",
            "title": "Limited release",
            "copy": "Made in small batches"
          }
        }
      ]
    }
  ]
}
{% endschema %}
