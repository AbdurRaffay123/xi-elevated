{%- doc -%}
  XI product media — main image + thumbnail row on light gray surface.

  @param {object} product - Shopify product object
{%- enddoc -%}

{% liquid
  assign xi_media_widths = '400, 600, 800, 1000, 1200, 1600'
  assign xi_primary_media = product.selected_or_first_available_variant.featured_media | default: product.featured_media
  assign xi_primary_image_url = blank
  if xi_primary_media != blank
    assign xi_primary_image_url = xi_primary_media | image_url: width: 2000
  endif
%}

<div class="xi-product-media" data-xi-product-media>
  <div class="xi-product-media__stage">
    {%- if xi_primary_media != blank -%}
      {%- for media in product.media -%}
        {%- liquid
          if forloop.first
            assign xi_frame_loading = 'eager'
            assign xi_frame_fetchpriority = 'high'
          else
            assign xi_frame_loading = 'lazy'
            assign xi_frame_fetchpriority = 'low'
          endif

          assign xi_frame_alt = media.alt | default: product.title
        -%}
        <figure
          class="xi-product-media__frame{% if forloop.first %} is-active{% endif %}"
          data-xi-product-media-frame
          data-media-id="{{ media.id }}"
          {% unless forloop.first %}hidden{% endunless %}
        >
          {{
            media.preview_image
            | image_url: width: 1600
            | image_tag:
              widths: xi_media_widths,
              sizes: '(min-width: 990px) 50vw, 100vw',
              loading: xi_frame_loading,
              fetchpriority: xi_frame_fetchpriority,
              alt: xi_frame_alt,
              class: 'xi-product-media__image',
              decoding: 'async'
          }}
        </figure>
      {%- endfor -%}

      {%- if xi_primary_image_url != blank -%}
        <a
          class="xi-product-media__zoom"
          href="{{ xi_primary_image_url }}"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="View larger product image"
        >
          {% render 'xi-icons', icon: 'search', size: 'sm' %}
        </a>
      {%- endif -%}
    {%- else -%}
      <figure class="xi-product-media__frame is-active" data-xi-product-media-frame>
        {{ 'product-1' | placeholder_svg_tag: 'xi-product-media__placeholder' }}
      </figure>
    {%- endif -%}
  </div>

  {%- if product.media.size > 1 -%}
    <div class="xi-product-media__thumbs-bar" data-xi-product-media-thumbs-bar>
      <button
        type="button"
        class="xi-product-media__thumbs-nav xi-product-media__thumbs-nav--prev"
        data-xi-product-media-prev
        aria-label="Previous thumbnails"
        hidden
      >
        {%- render 'xi-icons', icon: 'chevron-left', size: 'sm', stroke_width: 1.5 -%}
      </button>

      <div class="xi-product-media__thumbs-viewport" data-xi-product-media-viewport>
        <ul class="xi-product-media__thumbs" role="list" data-xi-product-media-thumbs>
          {%- for media in product.media -%}
            <li>
              <button
                type="button"
                class="xi-product-media__thumb{% if forloop.first %} is-active{% endif %}"
                data-xi-product-media-thumb
                data-media-id="{{ media.id }}"
                aria-label="{{ media.alt | default: product.title | escape }}"
                aria-current="{% if forloop.first %}true{% else %}false{% endif %}"
              >
                {{
                  media.preview_image
                  | image_url: width: 200
                  | image_tag:
                    widths: '100, 150, 200',
                    sizes: '80px',
                    loading: 'lazy',
                    alt: '',
                    class: 'xi-product-media__thumb-image',
                    decoding: 'async'
                }}
              </button>
            </li>
          {%- endfor -%}
        </ul>
      </div>

      <button
        type="button"
        class="xi-product-media__thumbs-nav xi-product-media__thumbs-nav--next"
        data-xi-product-media-next
        aria-label="Next thumbnails"
        hidden
      >
        {%- render 'xi-icons', icon: 'chevron-right', size: 'sm', stroke_width: 1.5 -%}
      </button>
    </div>
  {%- endif -%}
</div>
