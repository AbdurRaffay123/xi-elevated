{%- doc -%}
  XI-styled variant picker wired to Horizon variant-picker JS.

  @param {object} product - Shopify product object
  @param {object} section - Parent section object
{%- enddoc -%}

{% unless product.has_only_default_variant %}
  <variant-picker
    class="xi-product__variant-picker variant-picker"
    data-section-id="{{ section.id }}"
    data-product-id="{{ product.id }}"
    data-block-id="{{ section.id }}"
    data-product-url="{{ product.url }}"
    data-template-product-match="true"
  >
    <form class="variant-picker__form">
      {%- for product_option in product.options_with_values -%}
        {%- liquid
          assign option_name_downcase = product_option.name | downcase
          assign use_swatches = false
          if option_name_downcase == 'color' or option_name_downcase == 'colour'
            assign use_swatches = true
          endif
          assign fieldset_index = forloop.index0
        -%}

        <fieldset
          class="variant-option variant-option--buttons{% if use_swatches %} variant-option--swatches{% endif %}"
          data-fieldset-index="{{ fieldset_index }}"
          ref="fieldsets[]"
        >
          <legend class="xi-product__option-label">
            <span class="xi-product__option-name">{{ product_option.name | escape }}</span>
            <span class="xi-product__option-value variant-option__swatch-value">{{ product_option.selected_value | escape }}</span>
          </legend>

          <div class="xi-product__option-values">
            {%- for product_option_value in product_option.values -%}
              {%- liquid
                assign xi_swatch_key = product_option_value | downcase | strip
                case xi_swatch_key
                  when 'charcoal', 'dark grey', 'dark gray', 'grey', 'gray'
                    assign xi_swatch_key = 'charcoal'
                  when 'black'
                    assign xi_swatch_key = 'black'
                  when 'oatmeal', 'cream', 'beige', 'tan'
                    assign xi_swatch_key = 'oatmeal'
                  when 'sage', 'green', 'olive'
                    assign xi_swatch_key = 'sage'
                  when 'blue', 'sky', 'cobalt'
                    assign xi_swatch_key = 'blue'
                  when 'navy', 'midnight'
                    assign xi_swatch_key = 'navy'
                  when 'sand', 'stone', 'taupe'
                    assign xi_swatch_key = 'sand'
                  when 'burgundy', 'wine', 'maroon', 'red'
                    assign xi_swatch_key = 'burgundy'
                  else
                    assign xi_swatch_key = 'charcoal'
                endcase
              -%}

              <label class="variant-option__button-label{% if use_swatches %} variant-option__button-label--has-swatch{% endif %}">
                <input
                  type="radio"
                  name="{{ product_option.name | escape }}-{{ section.id }}-{{ product.id }}"
                  value="{{ product_option_value | escape }}"
                  aria-label="{{ product_option_value.name | escape }}"
                  {% if product_option_value.available == false %}
                    aria-disabled="true"
                  {% endif %}
                  data-fieldset-index="{{ fieldset_index }}"
                  data-input-index="{{ forloop.index0 }}"
                  data-input-id="{{ product_option.position }}-{{ forloop.index0 }}"
                  data-option-value-id="{{ product_option_value.id }}"
                  data-option-available="{{ product_option_value.available }}"
                  data-connected-product-url="{{ product_option_value.product_url }}"
                  {% if product_option_value.variant.id %}
                    data-variant-id="{{ product_option_value.variant.id }}"
                  {% endif %}
                  {% if product_option_value.selected %}
                    data-current-checked="true"
                    checked
                  {% else %}
                    data-current-checked="false"
                  {% endif %}
                >
                {% if use_swatches %}
                  {%- liquid
                    assign featured_media = product_option_value.variant.featured_media
                    if featured_media == blank and product_option_value.product_url
                      assign featured_media = product_option_value.variant.product.featured_media
                    endif
                    assign has_swatch_data = false
                    if product_option_value.swatch.color or product_option_value.swatch.image
                      assign has_swatch_data = true
                    endif
                  -%}
                  {% if has_swatch_data or settings.show_variant_image and featured_media %}
                    {% render 'swatch',
                      swatch: product_option_value.swatch,
                      variant_image: featured_media,
                      mode: 'unscaled'
                    %}
                  {% else %}
                    <span class="xi-product__color-swatch" data-color="{{ xi_swatch_key }}" aria-hidden="true"></span>
                  {% endif %}
                {% else %}
                  <span class="variant-option__button-label__text" data-key="variant-option-text">
                    {{- product_option_value | escape -}}
                  </span>
                {% endif %}
              </label>
            {%- endfor -%}
          </div>
        </fieldset>
      {%- endfor -%}

      <script type="application/json">
        {{ product.selected_or_first_available_variant | json }}
      </script>
    </form>
  </variant-picker>
{% endunless %}
